# SQM Hungary — /api/lead környezeti változók (Vercel → Settings → Environment Variables)
# Másold be a valós értékeket a Vercel projektbe (Production / Preview / Development).
# Ezek SZERVEROLDALI változók — NE kerüljenek a kliensoldali HTML-be.

# --- Meta Conversions API (CAPI) ---
META_PIXEL_ID=                 # Meta Pixel ID (ugyanaz, mint a kliens SITE_CONFIG-ban)
META_CAPI_ACCESS_TOKEN=        # CAPI access token (Events Manager → Settings → Conversions API)
META_TEST_EVENT_CODE=          # opcionális: teszteseményekhez (Events Manager → Test Events)

# --- n8n lead-továbbítás (CRM / automatizáció) ---
N8N_WEBHOOK_URL=               # n8n webhook URL. Ha üres → DEV mód (csak szerver-log, nincs továbbítás)
N8N_WEBHOOK_SECRET=            # opcionális: Authorization: Bearer <secret> fejléchez

# --- Biztonság (opcionális) ---
ALLOWED_ORIGINS=               # opcionális, vesszővel: https://sqm-hungary.hu,https://www.sqm-hungary.hu
                               # ha üres → minden origin engedélyezett
